import React, { useEffect, useState } from 'react';
import { NavigationContainer } from '@react-navigation/native';
import { createBottomTabNavigator } from '@react-navigation/bottom-tabs';
import { Ionicons } from '@expo/vector-icons';
import {
  View, Text, StyleSheet, FlatList, TouchableOpacity,
  ActivityIndicator, ScrollView, Linking, Image
} from 'react-native';

const Tab = createBottomTabNavigator();
const API_URL = 'https://plataforma-geracao-sonica.onrender.com/api';

// TELA HOME
function HomeScreen({ navigation }) {
  const [destaques, setDestaques] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetch(`${API_URL}/estabelecimentos`)
      .then(r => r.json())
      .then(data => {
        setDestaques(data.slice(0, 5));
        setLoading(false);
      })
      .catch(() => setLoading(false));
  }, []);

  if (loading) {
    return <View style={styles.center}><ActivityIndicator size="large" color="#FF6B00" /></View>;
  }

  return (
    <ScrollView style={styles.container}>
      <Text style={styles.logo}>GERAÇÃO SÔNICA</Text>
      <Text style={styles.subtitle}>Ribeirão Preto - SP</Text>

      <Text style={styles.sectionTitle}>🔥 Em Destaque</Text>
      {destaques.map(item => (
        <TouchableOpacity
          key={item.id}
          style={styles.card}
          onPress={() => navigation.navigate('Estabelecimento', { id: item.id })}
        >
          <Image source={{ uri: item.imagem }} style={styles.cardImage} />
          <View style={styles.cardInfo}>
            <Text style={styles.cardTitle}>{item.nome}</Text>
            <Text style={styles.cardDesc}>{item.descricao}</Text>
          </View>
        </TouchableOpacity>
      ))}

      <TouchableOpacity
        style={styles.botaoExplorar}
        onPress={() => navigation.navigate('Explorar')}
      >
        <Text style={styles.botaoTexto}>Explorar Todos</Text>
      </TouchableOpacity>
    </ScrollView>
  );
}

// TELA EXPLORAR
function ExplorarScreen({ navigation }) {
  const [estabelecimentos, setEstabelecimentos] = useState([]);
  const [categoria, setCategoria] = useState('todas');
  const [loading, setLoading] = useState(true);

  const categorias = [
    { id: 'todas', nome: 'Todas' },
    { id: 'alto_padrao', nome: 'Alto Padrão' },
    { id: 'classe_media', nome: 'Classe Média' },
    { id: 'popular', nome: 'Popular' },
  ];

  useEffect(() => {
    setLoading(true);
    const url = categoria === 'todas'
      ? `${API_URL}/estabelecimentos`
      : `${API_URL}/estabelecimentos?categoria=${categoria}`;

    fetch(url)
      .then(r => r.json())
      .then(data => {
        setEstabelecimentos(data);
        setLoading(false);
      })
      .catch(() => setLoading(false));
  }, [categoria]);

  return (
    <View style={styles.container}>
      <Text style={styles.sectionTitle}>Explorar</Text>

      <ScrollView horizontal style={styles.filtros}>
        {categorias.map(cat => (
          <TouchableOpacity
            key={cat.id}
            style={[styles.filtroBtn, categoria === cat.id && styles.filtroAtivo]}
            onPress={() => setCategoria(cat.id)}
          >
            <Text style={[styles.filtroTexto, categoria === cat.id && styles.filtroTextoAtivo]}>
              {cat.nome}
            </Text>
          </TouchableOpacity>
        ))}
      </ScrollView>

      {loading ? (
        <ActivityIndicator size="large" color="#FF6B00" />
      ) : (
        <FlatList
          data={estabelecimentos}
          keyExtractor={item => item.id}
          renderItem={({ item }) => (
            <TouchableOpacity
              style={styles.card}
              onPress={() => navigation.navigate('Estabelecimento', { id: item.id })}
            >
              <Image source={{ uri: item.imagem }} style={styles.cardImage} />
              <View style={styles.cardInfo}>
                <Text style={styles.cardTitle}>{item.nome}</Text>
                <Text style={styles.cardDesc}>{item.descricao}</Text>
                <Text style={styles.cardRegiao}>{item.regiao.replace('_', ' ')}</Text>
              </View>
            </TouchableOpacity>
          )}
        />
      )}
    </View>
  );
}

// TELA ESTABELECIMENTO
function EstabelecimentoScreen({ route }) {
  const [est, setEst] = useState(null);
  const { id } = route.params;

  useEffect(() => {
    fetch(`${API_URL}/estabelecimentos/${id}`)
      .then(r => r.json())
      .then(data => setEst(data))
      .catch(() => {});
  }, [id]);

  if (!est) return <View style={styles.center}><ActivityIndicator size="large" color="#FF6B00" /></View>;

  return (
    <ScrollView style={styles.container}>
      <Image source={{ uri: est.imagem }} style={styles.detalheImagem} />
      <Text style={styles.detalheTitulo}>{est.nome}</Text>
      <Text style={styles.detalheDesc}>{est.descricao}</Text>

      <Text style={styles.sectionTitle}>🍽️ Cardápio</Text>
      {est.cardapio.map((item, index) => (
        <View key={index} style={styles.cardapioItem}>
          <Text style={styles.cardapioNome}>{item.nome}</Text>
          <Text style={styles.cardapioPreco}>{item.preco}</Text>
        </View>
      ))}

      <TouchableOpacity
        style={styles.botaoExplorar}
        onPress={() => Linking.openURL(`https://instagram.com/${est.instagram.replace('@', '')}`)}
      >
        <Text style={styles.botaoTexto}>Seguir no Instagram</Text>
      </TouchableOpacity>
    </ScrollView>
  );
}

// APP PRINCIPAL
export default function App() {
  return (
    <NavigationContainer>
      <Tab.Navigator
        screenOptions={({ route }) => ({
          tabBarIcon: ({ color, size }) => {
            let iconName;
            if (route.name === 'Home') iconName = 'home';
            else if (route.name === 'Explorar') iconName = 'search';
            return <Ionicons name={iconName} size={size} color={color} />;
          },
          tabBarActiveTintColor: '#FF6B00',
          tabBarInactiveTintColor: '#555',
          headerShown: false,
          tabBarStyle: { backgroundColor: '#0D0D0D', borderTopColor: '#1A1A2E' },
        })}
      >
        <Tab.Screen name="Home" component={HomeScreen} />
        <Tab.Screen name="Explorar" component={ExplorarScreen} />
      </Tab.Navigator>
    </NavigationContainer>
  );
}

